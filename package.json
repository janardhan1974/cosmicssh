{
  "name": "cosmicssh",
  "version": "0.0.2",
  "private": true,
  "description": "Personal SSH/SFTP client for Windows and Linux.",
  "homepage": "https://github.com/janardhan1974/mobajana",
  "author": {
    "name": "Janardhan Srinivasan",
    "email": "Janardhan.Srinivasan@gmail.com"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "predev": "node scripts/write-build-info.mjs",
    "dev": "node scripts/dev.mjs",
    "prebuild": "node scripts/write-build-info.mjs",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "dist": "npm run build && node scripts/dist.mjs",
    "dist:installer": "npm run build && node scripts/dist.mjs nsis",
    "dist:portable": "npm run build && node scripts/dist.mjs portable",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^4.3.0",
    "chokidar": "^3.6.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.12.0-beta.219",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.13.0-beta.219",
    "@xterm/xterm": "^6.1.0-beta.219",
    "electron-store": "^8.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ssh2": "^1.17.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  }
}
