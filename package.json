{
  "name": "cosmicssh",
  "version": "0.0.1",
  "private": true,
  "description": "Personal SSH/SFTP client for Windows.",
  "author": {
    "name": "Shriram Jana",
    "email": "shriram.j.iyengar@gmail.com"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "dist": "npm run build && electron-builder --win",
    "dist:installer": "npm run build && electron-builder --win nsis",
    "dist:portable": "npm run build && electron-builder --win portable"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^4.3.0",
    "chokidar": "^3.6.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron-store": "^8.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ssh2": "^1.17.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  }
}
